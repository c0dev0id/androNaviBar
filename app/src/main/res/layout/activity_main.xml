<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:clipChildren="false"
    android:orientation="horizontal">

    <!-- Left 2/3: reserved for pane content -->
    <FrameLayout
        android:id="@+id/reservedArea"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2" />

    <!-- Right 1/3: buttons + drag handle strip -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clipChildren="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/buttonPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="false"
            android:orientation="vertical"
            android:padding="4dp">

            <de.codevoid.andronavibar.LauncherButton
                android:id="@+id/button0"
                style="@style/Widget.AndroNaviBar.Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="@string/empty" />

            <de.codevoid.andronavibar.LauncherButton
                android:id="@+id/button1"
                style="@style/Widget.AndroNaviBar.Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="@string/empty" />

            <de.codevoid.andronavibar.LauncherButton
                android:id="@+id/button2"
                style="@style/Widget.AndroNaviBar.Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="@string/empty" />

            <de.codevoid.andronavibar.LauncherButton
                android:id="@+id/button3"
                style="@style/Widget.AndroNaviBar.Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="@string/empty" />

            <de.codevoid.andronavibar.LauncherButton
                android:id="@+id/button4"
                style="@style/Widget.AndroNaviBar.Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="@string/empty" />

            <de.codevoid.andronavibar.LauncherButton
                android:id="@+id/button5"
                style="@style/Widget.AndroNaviBar.Button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="@string/empty" />

        </LinearLayout>

        <!-- Drag handle strip — visible only while config pane is open -->
        <LinearLayout
            android:id="@+id/dragHandlePanel"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="4dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
