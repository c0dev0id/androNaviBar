<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Left 2/3: reserved for pane content -->
    <FrameLayout
        android:id="@+id/reservedArea"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_panel"
        android:clipToOutline="true" />

    <!-- Right 1/3: button column.
         FrameLayout holds the scrollable button list + the edit-mode chrome
         pinned to the bottom. The chrome container is GONE in display mode. -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/bg_panel"
        android:clipToOutline="true">

        <ScrollView
            android:id="@+id/buttonScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/buttonPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:divider="@drawable/divider_button"
                android:showDividers="middle" />

        </ScrollView>

        <!-- Edit mode chrome: + Add row and Done/Settings row.
             Pinned to the bottom; GONE in display mode. -->
        <LinearLayout
            android:id="@+id/editChromeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="@color/background_dark"
            android:padding="8dp"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
